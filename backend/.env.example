# App
APP_NAME=imap
APP_ENV=local
APP_DEBUG=true
APP_VERSION=0.1.0

# HTTP server
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# CORS
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
LOG_FILE=false
LOG_DIR=runtime_logs

# PostgreSQL
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=imap
PG_USER=postgres
PG_PASSWORD=postgres
PG_MIN_CONN=1
PG_MAX_CONN=10

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
